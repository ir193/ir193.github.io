&lt;span class="nx"&gt;c0077650&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e92d40f8&lt;/span&gt;        &lt;span class="nb"&gt;push&lt;/span&gt;    &lt;span class="p"&gt;{&lt;/span&gt;&lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r4&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r5&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r6&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r7&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;lr&lt;/span&gt;&lt;span class="p"&gt;}&lt;/span&gt;
&lt;span class="nx"&gt;c0077654&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e1a05000&lt;/span&gt;        &lt;span class="nx"&gt;mov&lt;/span&gt;     &lt;span class="nx"&gt;r5&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r0&lt;/span&gt;
&lt;span class="nx"&gt;c0077658&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;eb0040d6&lt;/span&gt;        &lt;span class="nx"&gt;bl&lt;/span&gt;      &lt;span class="nx"&gt;c00879b8&lt;/span&gt; &lt;span class="o"&gt;&amp;lt;&lt;/span&gt;&lt;span class="nx"&gt;prepare_creds&lt;/span&gt;&lt;span class="o"&gt;&amp;gt;&lt;/span&gt;
&lt;span class="nx"&gt;c007765c&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e2504000&lt;/span&gt;        &lt;span class="nx"&gt;subs&lt;/span&gt;    &lt;span class="nx"&gt;r4&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r0&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#0&lt;/span&gt;
&lt;span class="nx"&gt;c0077660&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="mi"&gt;0&lt;/span&gt;&lt;span class="nx"&gt;a000027&lt;/span&gt;        &lt;span class="nx"&gt;beq&lt;/span&gt;     &lt;span class="nx"&gt;c0077704&lt;/span&gt; &lt;span class="o"&gt;&amp;lt;&lt;/span&gt;&lt;span class="nb"&gt;sys_setuid&lt;/span&gt;&lt;span class="o"&gt;+&lt;/span&gt;&lt;span class="mh"&gt;0xb4&lt;/span&gt;&lt;span class="o"&gt;&amp;gt;&lt;/span&gt;
&lt;span class="nx"&gt;c0077664&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e1a0200d&lt;/span&gt;        &lt;span class="nx"&gt;mov&lt;/span&gt;     &lt;span class="nx"&gt;r2&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;sp&lt;/span&gt;
&lt;span class="nx"&gt;c0077668&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e3c23d7f&lt;/span&gt;        &lt;span class="nx"&gt;bic&lt;/span&gt;     &lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r2&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#8128&lt;/span&gt;   &lt;span class="p"&gt;;&lt;/span&gt; &lt;span class="mh"&gt;0x1fc0&lt;/span&gt;
&lt;span class="nx"&gt;c007766c&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e3c3303f&lt;/span&gt;        &lt;span class="nx"&gt;bic&lt;/span&gt;     &lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#63&lt;/span&gt;     &lt;span class="p"&gt;;&lt;/span&gt; &lt;span class="mh"&gt;0x3f&lt;/span&gt;
&lt;span class="nx"&gt;c0077670&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e3a00007&lt;/span&gt;        &lt;span class="nx"&gt;mov&lt;/span&gt;     &lt;span class="nx"&gt;r0&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#7&lt;/span&gt;
&lt;span class="nx"&gt;c0077674&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt;       &lt;span class="nx"&gt;e593300c&lt;/span&gt;        &lt;span class="nx"&gt;ldr&lt;/span&gt;     &lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="err"&gt;[&lt;/span&gt;&lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#12&lt;/span&gt;&lt;span class="cp"&gt;]&lt;/span&gt;
c0077678:       e59362fc        ldr     r6, &lt;span class="cp"&gt;[&lt;/span&gt;&lt;span class="nx"&gt;r3&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="vi"&gt;#764&lt;/span&gt;&lt;span class="cp"&gt;]&lt;/span&gt;  ; 0x2fc
