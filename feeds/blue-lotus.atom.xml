c0077680:       e3500000        cmp     r0, #0
c0077684:       1a00000a        bne     c00776b4 &lt;span class="nt"&gt;&amp;lt;sys&lt;/span&gt;&lt;span class="na"&gt;_setuid&lt;/span&gt;&lt;span class="err"&gt;+&lt;/span&gt;&lt;span class="na"&gt;0x64&lt;/span&gt;&lt;span class="nt"&gt;&amp;gt;&lt;/span&gt;
